{
  "search_settings": {
    "search_days": 30,
    "max_results": 150,
    "max_results_per_source": {
      "arxiv": 30,
      "journals": 50,
      "openalex": 70
    }
  },

  "data_sources": {
    "enabled": [
      "arxiv",
      "journals",
      "openalex"
    ],
    "journals": [
      "Advanced Materials",
      "ACS Applied Materials & Interfaces",
      "Journal of Materials Chemistry A",
      "Carbohydrate Polymers",
      "Advanced Functional Materials",
      "Chemical Engineering Journal",
      "Composites Part B: Engineering",
      "ACS Applied Materials & Interfaces",
      "ACS Nano",
      "Advanced Materials Technologies",
      "Cellulose",
      "Coatings",
      "Nano-Micro Letters",
      "Progress in Organic Coatings",
      "Small",
      "Advanced Fiber Materials",
      "Surfaces and Interfaces",
    ],
    "reports_by_source": true,
    "arxiv": {
      "fetch_timeout_seconds": 180
    }
  },

  "run_lock": {
    "max_age_hours": 12
  },

  "target_domains": {
    "domains": [
      "cond-mat.mtrl-sci",
      "physics.app-ph",
      "cond-mat.soft",
      "cs.HC",
      "cs.LG",
      "eess.SP"
    ]
  },

  "keywords": {
    "primary_keywords": {
      "weight": 1.0,
      "keywords": [
        "personal thermal management",
        "thermal management",
        "radiative cooling",
        "solar heating",
        "smart textile",
        "functional textile",
      ]
    },
    "enable_reference_extraction": false,
    "reference_keywords_config": {
      "max_keywords": 10,
      "similarity_threshold": 0.75,
      "weight_distribution": {
        "high_importance": {
          "weight": 1.0,
          "count": 3
        },
        "medium_importance": {
          "weight": 0.2,
          "count": 5
        },
        "low_importance": {
          "weight": 0.1,
          "count": 2
        }
      }
    },
    "research_context": "文献日报：我的研究方向是功能纺织材料、智能纺织品、个人热管理纺织品、辐射制冷、光热转换、纤维素基材料、棉织物、涂层织物和服装热湿舒适性。"
  },

  "scoring_settings": {
    "keyword_relevance_score": {
      "max_score_per_keyword": 10
    },
    "author_bonus": {
      "enabled": false,
      "expert_authors": [],
      "bonus_points": 5.0
    },
    "passing_score_formula": {
      "base_score": 0.1,
      "weight_coefficient": 0.03
    },
    "include_all_in_report": true
  },

  "paths": {
    "data_dir": "data",
    "reference_pdfs": "data/reference_pdfs",
    "reports": "data/reports",
    "downloaded_pdfs": "data/downloaded_pdfs",
    "history_dir": "data/history"
  },

  "keyword_tracker": {
    "enabled": true,
    "database": {
      "path": "data/keywords/keywords.db"
    },
    "normalization": {
      "enabled": true,
      "batch_size": 25
    },
    "trend_view": {
      "default_days": 30
    },
    "charts": {
      "bar_chart": {
        "top_n": 15
      },
      "trend_chart": {
        "top_n": 5
      }
    },
    "report": {
      "enabled": true,
      "frequency": "weekly"
    }
  },

  "notifications": {
    "enabled": true,
    "on_success": true,
    "on_failure": true,
    "attach_reports": true,
    "top_n": 5,
    "channels": {
      "email": {
        "enabled": false
      },
      "wechat_work": {
        "enabled": false
      },
      "dingtalk": {
        "enabled": true
      },
      "telegram": {
        "enabled": false
      },
      "slack": {
        "enabled": false
      },
      "generic_webhook": {
        "enabled": false
      }
    }
  },

  "retry": {
    "max_attempts": 5,
    "min_wait": 2,
    "max_wait": 60
  },

  "logging": {
    "rotation_type": "time",
    "keep_days": 30
  },

  "concurrency": {
    "enabled": true,
    "workers": 2
  },

  "pdf_parser": {
    "mode": "pymupdf",
    "mineru_model_version": "vlm",
    "poll_interval": 3,
    "poll_timeout": 300
  },

  "report_settings": {
    "enable_html_report": true,
    "enable_markdown_report": true,
    "directory_structure": "date_grouped"
  },

  "auto_update": {
    "enabled": true
  },

  "token_tracking": {
    "enabled": true
  },

  "proxy": {
    "enabled": false,
    "url": "",
    "no_proxy": "localhost,127.0.0.1",
    "scope": {
      "arxiv": true,
      "openalex": false,
      "semantic_scholar": false,
      "llm_api": false,
      "notifications": false,
      "update_check": false
    }
  },

  "webdav": {
    "enabled": false,
    "remote_path": "/arxiv-daily-researcher/",
    "sync_mode": "after_report",
    "cron_schedule": "0 23 * * *",
    "sync_configs": true,
    "sync_history": false,
    "sync_keywords": false,
    "sync_reports": false
  },

  "trend_research": {
    "default_date_range_days": 365,
    "max_results": 500,
    "sort_order": "ascending",
    "report_position": "end",
    "generate_tldr": true,
    "tldr_batch_size": 10,
    "output_formats": [
      "markdown",
      "html"
    ],
    "enabled_skills": [
      "comprehensive_analysis"
    ]
  }
}
