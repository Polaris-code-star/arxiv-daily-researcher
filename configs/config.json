{
  // ==================================================
  // Search Configuration
  // ==================================================
  "search_settings": {
    "search_days": 3,
    "max_results": 100,
    "max_results_per_source": {
      "arxiv": 100,
      "openalex": 70
    }
  },

  // ==================================================
  // Data Source Configuration
  // ==================================================
  "data_sources": {
   "enabled": [
  "arxiv",
  "journals"
],
    "journals": [
      "Advanced Materials",
      "ACS Applied Materials & Interfaces",
      "Journal of Materials Chemistry A",
      "Carbohydrate Polymers",
      "Energy & Buildings",
      "Chemical Engineering Journal",
      "Composites Part B: Engineering",
      "ACS Sustainable Chemistry & Engineering",
      "Materials Horizons"
    ],
    "arxiv": {
      "fetch_timeout_seconds": 180
    }
  },

  // ==================================================
  // Run Lock Configuration
  // ==================================================
  "run_lock": {
    "max_age_hours": 12
  },

  // ==================================================
  // ArXiv Target Domain Configuration
  // ==================================================
  "target_domains": {
  "domains": [
  "cond-mat.mtrl-sci",
  "physics.app-ph",
  "cond-mat.soft",
  "cs.HC",
  "cs.LG",
  "eess.SP"
]
  },

  // ==================================================
  // Keyword Configuration
  // ==================================================
  "keywords": {
    "primary_keywords": {
      "weight": 1.0,
      "keywords": [
        "smart textile",
      "functional textile",
      "wearable textile",
      "thermal comfort",
      "moisture management",
      "Solar heating",
      "radiative cooling",
      "personal thermal management",
      "Janus textile",
      "Passive radiative cooling",
      "Energy saving",
      "Cotton fabric",
      "Cellulose acetate"
      ]
    },
    "enable_reference_extraction": false,
    "reference_keywords_config": {
      "max_keywords": 10,
      "similarity_threshold": 0.75,
      "weight_distribution": {
        "high_importance": {
          "weight": 1.0,
          "count": 3
        },
        "medium_importance": {
          "weight": 0.2,
          "count": 5
        },
        "low_importance": {
          "weight": 0.1,
          "count": 2
        }
      }
    },
  "research_context": "我的研究方向是功能纺织材料、智能纺织品、个人热管理纺织品、辐射制冷、光热转换、醋酸纤维素、刮涂法制备。"
  },

  // ==================================================
  // Scoring Configuration
  // ==================================================
  "scoring_settings": {
    "keyword_relevance_score": {
      "max_score_per_keyword": 10
    },
    "author_bonus": {
      "enabled": false,
      "expert_authors": [],
      "bonus_points": 5.0
    },
    "passing_score_formula": {
      "base_score": 0.5,
      "weight_coefficient": 0.2
    },
    "include_all_in_report": false
  },

  // ==================================================
  // Path Configuration
  // ==================================================
  "paths": {
    "data_dir": "data",
    "reference_pdfs": "data/reference_pdfs",
    "reports": "data/reports",
    "downloaded_pdfs": "data/downloaded_pdfs",
    "history_dir": "data/history"
  },

  // ==================================================
  // Keyword Trend Tracking Configuration
  // ==================================================
  "keyword_tracker": {
    "enabled": true,
    "database": {
      "path": "data/keywords/keywords.db"
    },
    "normalization": {
      "enabled": true,
      "batch_size": 25
    },
    "trend_view": {
      "default_days": 30
    },
    "charts": {
      "bar_chart": {
        "top_n": 15
      },
      "trend_chart": {
        "top_n": 5
      }
    },
    "report": {
      "enabled": true,
      "frequency": "daily"
    }
  },

  // ==================================================
  // Notification Configuration
  // ==================================================
  "notifications": {
    "enabled": true,
    "on_success": true,
    "on_failure": true,
    "attach_reports": true,
    "top_n": 10,
    "channels": {
      "email": {
        "enabled": true
      },
      "wechat_work": {
        "enabled": false
      },
      "dingtalk": {
        "enabled": false
      },
      "telegram": {
        "enabled": false
      },
      "slack": {
        "enabled": false
      },
      "generic_webhook": {
        "enabled": false
      }
    }
  },

  // ==================================================
  // Retry Configuration
  // ==================================================
  "retry": {
    "max_attempts": 5,
    "min_wait": 2,
    "max_wait": 60
  },

  // ==================================================
  // Logging Configuration
  // ==================================================
  "logging": {
    "rotation_type": "time",
    "keep_days": 30
  },

  // ==================================================
  // Concurrency Configuration
  // ==================================================
  "concurrency": {
    "enabled": true,
    "workers": 2
  },

  // ==================================================
  // PDF Parser Configuration
  // ==================================================
  "pdf_parser": {
    "mode": "pymupdf",
    "mineru_model_version": "vlm",
    "poll_interval": 3,
    "poll_timeout": 300
  },

  // ==================================================
  // Report Configuration
  // ==================================================
  "report_settings": {
    "enable_html_report": true,
    "enable_markdown_report": true,
    "directory_structure": "date_grouped"
  },

  // ==================================================
  // Auto-update Configuration
  // ==================================================
  "auto_update": {
    "enabled": true
  },

  // ==================================================
  // Token Tracking Configuration
  // ==================================================
  "token_tracking": {
    "enabled": true
  },

  // ==================================================
  // Network Proxy Configuration
  // ==================================================
  "proxy": {
    "enabled": false,
    "url": "",
    "no_proxy": "localhost,127.0.0.1",
    "scope": {
      "arxiv": true,
      "openalex": false,
      "semantic_scholar": false,
      "llm_api": false,
      "notifications": false,
      "update_check": false
    }
  },

  // ==================================================
  // WebDAV Sync Configuration
  // ==================================================
  "webdav": {
    "enabled": false,
    "remote_path": "/arxiv-reports/",
    "sync_mode": "after_report",
    "cron_schedule": "0 23 * * *",
    "sync_configs": true,
    "sync_history": false,
    "sync_keywords": false,
    "sync_reports": true
  },

  // ==================================================
  // Trend Research Mode Configuration
  // ==================================================
  "trend_research": {
    "default_date_range_days": 365,
    "max_results": 500,
    "sort_order": "ascending",
    "report_position": "end",
    "generate_tldr": true,
    "tldr_batch_size": 10,
    "output_formats": [
      "markdown",
      "html"
    ],
    "enabled_skills": [
      "comprehensive_analysis"
    ]
  }
}
